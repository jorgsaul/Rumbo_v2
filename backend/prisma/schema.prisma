generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                @id @default(cuid())
  username         String                @unique
  fullName         String
  email            String                @unique
  password         String?
  role             Role                  @default(STUDENT)
  educationLevel   EducationLevel?
  bio              String?
  avatarUrl        String?
  bannerUrl        String?
  isPrivate        Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  avatarPublicId   String?
  bannerPublicId   String?
  googleId         String?
  provider         String                @default("local")
  isActive         Boolean               @default(true)
  resetToken       String?
  resetTokenExpiry DateTime?
  comments         Comment[]
  favorites        Favorite[]
  following        Follow[]              @relation("follower")
  followers        Follow[]              @relation("following")
  forums            Forum[]
  forumRequests     ForumRequest[]
  knowledgeResults KnowledgeTestResult[]
  likes            Like[]
  posts            Post[]
  reports          Report[]
  tickets          Ticket[]
  vocalTestResults VocalTestResult[]
}

model PendingVerification {
  email  String   @id
  code   String
  expiry DateTime
}

model Post {
  id            String           @id @default(cuid())
  authorId      String
  title         String?
  content       String
  mediaUrl      String?
  moderation    ModerationStatus @default(PENDING)
  isHidden      Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  mediaPublicId String?
  forumId       String?
  comments      Comment[]
  favorites     Favorite[]
  likes         Like[]
  author        User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  forum         Forum?           @relation(fields: [forumId], references: [id])
  tags          PostTag[]
  reports       Report[]
}

model Comment {
  id            String    @id @default(cuid())
  postId        String
  authorId      String
  content       String
  isHidden      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  parentId      String?
  updatedAt     DateTime  @updatedAt
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("replies", fields: [parentId], references: [id])
  replies Comment[] @relation("replies")
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Favorite {
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  postId     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  post       Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model TagCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  color       String
  tags        Tag[]
}

model Tag {
  id         String      @id @default(cuid())
  name       String      @unique
  categoryId String
  posts      PostTag[]
  category   TagCategory @relation(fields: [categoryId], references: [id])
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
}

model Test {
  id               String                @id @default(cuid())
  title            String
  description      String?
  type             TestType
  status           TestStatus            @default(DRAFT)
  estimatedMinutes Int                   @default(15)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  knowledgeResults KnowledgeTestResult[]
  questions        Question[]
  vocalResults     VocalTestResult[]
}

model Question {
  id         String       @id @default(cuid())
  testId     String
  text       String
  order      Int
  pilar      IkigaiPilar?
  weights    Json?
  imageUrl   String?
  statements Json?
  options    Option[]
  test       Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model Option {
  id         String   @id @default(cuid())
  questionId String
  label      String
  text       String
  imageUrl   String?
  isCorrect  Boolean  @default(false)
  order      Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model VocalTestResult {
  id                   String     @id @default(cuid())
  userId               String
  perfilTecnologico    Float      @default(0)
  perfilCientifico     Float      @default(0)
  perfilSalud          Float      @default(0)
  perfilAdministrativo Float      @default(0)
  perfilSocial         Float      @default(0)
  topCarreras          Json
  resultadosCompletos  Json
  scoreGlobal          Float      @default(0)
  zonaIkigai           IkigaiZone
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  testId               String
  test                 Test       @relation(fields: [testId], references: [id])
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KnowledgeTestResult {
  id             String   @id @default(cuid())
  userId         String
  testId         String
  score          Float
  correctAnswers Int
  totalQuestions Int
  createdAt      DateTime @default(now())
  test           Test     @relation(fields: [testId], references: [id])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String
  category    TicketCategory @default(OTHER)
  status      TicketStatus   @default(OPEN)
  adminReply  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Forum {
  id           String         @id @default(cuid())
  name         String         @unique
  description  String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  createdById  String
  createdBy    User           @relation(fields: [createdById], references: [id])
  requests     ForumRequest[]
  posts        Post[]
}

model ForumRequest {
  id          String             @id @default(cuid())
  name        String
  description String?
  status      ForumRequestStatus @default(PENDING)
  userId      String
  createdAt   DateTime           @default(now())
  forumId     String?
  forum       Forum?             @relation(fields: [forumId], references: [id])
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  AUTHOR
  ADMIN
}

enum EducationLevel {
  MIDDLE_SCHOOL
  HIGH_SCHOOL
  UNIVERSITY
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum ReportStatus {
  PENDING
  RESOLVED
}

enum IkigaiZone {
  PROPOSITO_FUERTE
  PROFESION_IDEAL
  EXPLORAR_MAS
}

enum TestType {
  VOCATIONAL
  KNOWLEDGE
}

enum TestStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum IkigaiPilar {
  PASION
  VOCACION
  PROFESION
  MISION
}

enum TicketStatus {
  OPEN
  IN_REVIEW
  RESOLVED
}

enum TicketCategory {
  BUG
  QUESTION
  SUGGESTION
  OTHER
}

enum ForumRequestStatus {
  PENDING
  APPROVED
  REJECTED
}
